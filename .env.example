# ----------------------------------------------------------------------------
# IP Inscription (Bitcoin Ordinals) — frontend environment (web/.env.local)
# Copy this file to web/.env.local and fill in the values. NEVER commit secrets.
#
# DEFAULT = DEMO MODE: with NO variables set, the app runs a zero-config,
# click-through demo (real SHA-256 hashing; simulated wallet + inscription;
# records saved in the visitor's browser). Great for a Vercel demo URL.
# ----------------------------------------------------------------------------

# Demo mode. "true" (or unset) = simulated, zero-config. Set to "false" to use a
# REAL Bitcoin wallet + IPFS (then PINATA_JWT below is required).
NEXT_PUBLIC_DEMO_MODE=true

# Bitcoin network label/target. One of: Mainnet | Testnet | Testnet4 | Signet | Regtest
NEXT_PUBLIC_BTC_NETWORK=Signet

# Public IPFS gateway used to display pinned content (real mode only).
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ---- Optional Phase-2 monetization hook (real mode only) ----
# Add a flat app fee (in sats) sent to your address on each inscription.
NEXT_PUBLIC_APP_FEE_SATS=0
NEXT_PUBLIC_APP_FEE_ADDRESS=

# ============================================================================
# The settings below are ONLY needed when NEXT_PUBLIC_DEMO_MODE=false (real mode)
# ============================================================================

# ---- SERVER ONLY (not exposed to the browser) ----
# Pinata JWT used by the /api/ipfs routes to pin files + metadata.
# Create one at https://app.pinata.cloud (API Keys -> New Key -> JWT).
PINATA_JWT=

# App-operated registry index store. On Vercel, create an Upstash Redis (KV)
# database and paste its REST credentials here. If omitted, the app falls back to
# a local JSON file at web/.registry/registry.json (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
